%MACRO SUMMARY (DATOS, NUM, VARCLASS, VARRESUM);

DATA DATOS;
SET &DATOS; RUN;

PROC SORT DATA=DATOS; BY &VARCLASS;
             PROC SUMMARY DATA=DATOS; 
		      BY  &VARCLASS;
			 VAR &VARRESUM;
		     OUTPUT OUT=RESUL&NUM(KEEP= &VARCLASS &VARRESUM  )SUM= ;
			 RUN;	 
%MEND SUMMARY ;

